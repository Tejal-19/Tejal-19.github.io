---
import Icon from './Icon.astro';

const channels = [
  { icon: 'mail' as const, label: 'Email', value: 'tejal.bedmutha@gmail.com', href: 'mailto:tejal.bedmutha@gmail.com' },
  { icon: 'phone' as const, label: 'Phone', value: '+1 (646) 464-6621', href: 'tel:+16464646621' },
  { icon: 'linkedin' as const, label: 'LinkedIn', value: 'tejal-bedmutha', href: 'https://www.linkedin.com/in/tejal-bedmutha/' },
  { icon: 'github' as const, label: 'GitHub', value: 'Tejal-19', href: 'https://github.com/Tejal-19' },
];
---

<section class="section" id="contact">
  <div class="container">
    <h2 class="section-title">Get in <span class="accent">touch</span></h2>
    <p class="contact-intro reveal">
      I'm always open to discussing research opportunities, collaborations, or just
      having a chat about robotics. Reach out through any of the channels below.
    </p>

    <div class="contact-grid">
      {channels.map((c) => (
        <a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer" class="contact-card reveal">
          <span class="contact-icon"><Icon name={c.icon} /></span>
          <span>
            <span class="contact-label mono">{c.label}</span>
            <span class="contact-value">{c.value}</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact-intro {
    color: var(--color-text-dim);
    max-width: 56ch;
    margin-bottom: var(--space-8);
  }

  .contact-grid {
    display: grid;
    gap: var(--space-4);
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color 0.2s, transform 0.2s var(--ease);
  }

  .contact-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-sm);
    background: var(--color-accent-dim);
    color: var(--color-accent);
    font-size: var(--text-lg);
    flex-shrink: 0;
  }

  .contact-card > span:last-child {
    display: flex;
    flex-direction: column;
  }

  .contact-label {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-value {
    font-size: var(--text-base);
  }

  @media (min-width: 720px) {
    .contact-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
