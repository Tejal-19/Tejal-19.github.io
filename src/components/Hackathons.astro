---
import { hackathons } from '../data/hackathons';
---

<section class="section" id="hackathons">
  <div class="container">
    <h2 class="section-title">Hackathons</h2>

    <div class="hackathons-grid">
      {hackathons.map((h) => (
        <article class="hackathon-card reveal">
          <div class="hackathon-header">
            <span class:list={['hackathon-result', h.result === 'Winner' ? 'result-winner' : 'result-runner-up']}>
              {h.result}
            </span>
            <span class="hackathon-date mono">{h.date}</span>
          </div>
          <h3 class="hackathon-name">{h.event}</h3>
          <ul class="hackathon-bullets">
            {h.bullets.map((b) => <li>{b}</li>)}
          </ul>
          <ul class="tag-list">
            {h.tags.map((t) => <li>{t}</li>)}
          </ul>
          {h.link && (
            <a href={h.link} target="_blank" rel="noreferrer" class="hackathon-link">View project →</a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .hackathons-grid {
    display: grid;
    gap: var(--space-6);
  }

  .hackathon-card {
    background: var(--color-bg-inset);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .hackathon-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }

  .hackathon-result {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 2px var(--space-3);
    border-radius: var(--radius-sm);
  }

  .result-winner {
    background: var(--color-annotate-dim);
    color: var(--color-annotate);
  }

  .result-runner-up {
    background: var(--color-border);
    color: var(--color-text-dim);
  }

  .hackathon-date {
    color: var(--color-text-faint);
    font-size: var(--text-xs);
  }

  .hackathon-name {
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
  }

  .hackathon-bullets {
    list-style: none;
    color: var(--color-text-dim);
    font-size: var(--text-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .hackathon-bullets li {
    padding-left: var(--space-4);
    position: relative;
  }

  .hackathon-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 1px;
    background: var(--color-accent);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin-bottom: var(--space-4);
  }

  .tag-list li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 2px var(--space-2);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    color: var(--color-text-faint);
  }

  .hackathon-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
  }

  @media (min-width: 860px) {
    .hackathons-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
