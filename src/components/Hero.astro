---
import Icon from './Icon.astro';
---

<section class="hero grid-bg" id="intro">
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="annotate">// tejal_bedmutha.init()</p>
      <h1 class="hero-name">Tejal Bedmutha<span class="accent">.</span></h1>
      <p class="hero-role">A <span class="accent mono" id="typewriter"></span><span class="hero-cursor">|</span></p>
      <p class="hero-tagline">
        Robotics researcher focused on motion planning, perception, and autonomous
        underwater vehicles. Currently pursuing an M.S. in Computer Science
        (Robotics) at Columbia University.
      </p>

      <div class="hero-actions">
        <a href="/projects" class="btn btn-primary">View my work</a>
        <a href="#contact" class="btn btn-outline">Get in touch</a>
      </div>

      <div class="hero-social">
        <a href="https://www.linkedin.com/in/tejal-bedmutha/" target="_blank" rel="noreferrer" aria-label="LinkedIn"><Icon name="linkedin" /></a>
        <a href="https://github.com/Tejal-19" target="_blank" rel="noreferrer" aria-label="GitHub"><Icon name="github" /></a>
        <a href="mailto:tejal.bedmutha@gmail.com" aria-label="Email"><Icon name="mail" /></a>
      </div>
    </div>

    <div class="hero-portrait" data-parallax="-0.12">
      <img src="/images/profile_pic_2.jpeg" alt="Tejal Bedmutha" width="360" height="360" />
      <div class="hero-portrait-frame"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    min-height: 92vh;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    gap: var(--space-12);
    align-items: center;
  }

  .hero-name {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl));
    margin-block: var(--space-4) var(--space-2);
  }

  .hero-role {
    font-size: var(--text-xl);
    color: var(--color-text-dim);
    margin-bottom: var(--space-4);
    min-height: 1.6em;
  }

  .hero-cursor {
    color: var(--color-accent);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .hero-tagline {
    max-width: 46ch;
    color: var(--color-text-dim);
    margin-bottom: var(--space-8);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    transition: transform 0.2s var(--ease), background 0.2s, border-color 0.2s;
  }

  .btn:hover { transform: translateY(-2px); }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .btn-primary:hover { background: var(--color-accent-strong); }

  .btn-outline {
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
  }

  .btn-outline:hover { border-color: var(--color-accent); color: var(--color-accent); }

  .hero-social {
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-xl);
    color: var(--color-text-dim);
  }

  .hero-social a:hover { color: var(--color-accent); }

  .hero-portrait {
    position: relative;
    justify-self: center;
    width: min(320px, 70vw);
  }

  .hero-portrait img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius-lg);
    filter: grayscale(0.15);
  }

  .hero-portrait-frame {
    position: absolute;
    inset: 14px -14px -14px 14px;
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-lg);
    z-index: -1;
  }

  @media (min-width: 860px) {
    .hero-inner {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }
</style>

<script>
  import { typewriter } from '../lib/typewriter';

  const el = document.getElementById('typewriter');
  if (el) {
    typewriter(el, ['Robotics Researcher.', 'Motion Planning Engineer.', 'Systems Builder.']);
  }
</script>
