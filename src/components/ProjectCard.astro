---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, cover, coverAlt, tags, links } = project.data;
---

<article class="project-card reveal">
  <a href={`/projects/${project.id}`} class="project-media">
    <img src={cover} alt={coverAlt} loading="lazy" />
  </a>
  <div class="project-body">
    <h3><a href={`/projects/${project.id}`}>{title}</a></h3>
    <p class="project-summary">{summary}</p>
    <ul class="tag-list">
      {tags.slice(0, 3).map((t) => <li>{t}</li>)}
    </ul>
    <div class="project-links">
      <a href={`/projects/${project.id}`} class="project-readmore">Read more →</a>
      {links?.github && (
        <a href={links.github} target="_blank" rel="noreferrer" aria-label="View on GitHub"><Icon name="github" /></a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    background: var(--color-bg-inset);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s var(--ease);
  }

  .project-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
  }

  .project-media {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg);
  }

  .project-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-body {
    padding: var(--space-6);
  }

  .project-body h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .project-body h3 a:hover { color: var(--color-accent); }

  .project-summary {
    color: var(--color-text-dim);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin-bottom: var(--space-4);
  }

  .tag-list li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 2px var(--space-2);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    color: var(--color-text-faint);
  }

  .project-links {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .project-readmore { color: var(--color-accent); }
  .project-links > a[aria-label] { color: var(--color-text-dim); font-size: var(--text-base); }
  .project-links > a[aria-label]:hover { color: var(--color-accent); }
</style>
