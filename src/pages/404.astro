---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found" description="Page not found.">
  <main class="section not-found">
    <div class="container">
      <p class="annotate">// 404</p>
      <h1>No path found to this page<span class="accent">.</span></h1>
      <p>The planner couldn't find a route here — the goal cell might be unreachable.</p>
      <a href="/" class="mono">← Back home</a>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  h1 {
    font-size: var(--text-3xl);
    margin-block: var(--space-4) var(--space-2);
  }

  p {
    color: var(--color-text-dim);
    margin-bottom: var(--space-6);
  }

  a { color: var(--color-accent); }
</style>
